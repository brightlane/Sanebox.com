const fs = require("fs");
const path = require("path");

const AFFILIATE_URL = "https://try.sanebox.com/efdrajzfvk2c";

// Inject affiliate link safely
function injectAffiliate(html) {
  if (html.includes(AFFILIATE_URL)) return html;

  return html.replace(
    "</body>",
    `
    <div style="padding:20px;margin-top:40px;border-top:1px solid #ccc;">
      <h3>Try SaneBox</h3>
      <p>Automatically clean your inbox and reduce email overload.</p>
      <a href="${AFFILIATE_URL}" target="_blank">
        👉 Get SaneBox Here
      </a>
    </div>
</body>`
  );
}

// Enhance SEO without rewriting pages
function enhanceSEO(html) {
  if (!html.includes("<meta name=\"description\"")) {
    html = html.replace(
      "<head>",
      `<head>
<meta name="description" content="SaneBox email productivity guide and inbox optimization tips">`
    );
  }
  return html;
}

// Process files safely
function processFile(filePath) {
  let html = fs.readFileSync(filePath, "utf8");

  html = enhanceSEO(html);
  html = injectAffiliate(html);

  fs.writeFileSync(filePath, html);
  console.log("Enhanced:", filePath);
}

// Run on key pages only
const targets = [
  "index.html",
  "sanebox-review.html",
  "clean-email-inbox.html",
  "blog.html"
];

targets.forEach((file) => {
  if (fs.existsSync(file)) {
    processFile(file);
  }
});

console.log("Done: site enhanced safely");
